# Environment variables for Ask the Claude Docs.
# Copy to .env.local (untracked) and fill in real values. This set is kept in
# lockstep with the zod schema in lib/env.ts (ENG-11). Never commit .env.local.

# Anthropic API key — funds the generation (answer) calls. Starts with "sk-".
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key — funds embeddings (text-embedding-3-small). Starts with "sk-".
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase pooled Postgres connection string (server-side only).
DATABASE_URL=postgresql://user:password@host:6543/postgres

# Upstash Redis REST endpoint — rate limiter + spend counter.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io

# Upstash Redis REST token — paired with the URL above.
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Portfolio URL rendered in the site footer (UX-13). Server-only, not secret.
PORTFOLIO_URL=https://your-portfolio.example.com
